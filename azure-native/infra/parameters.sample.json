{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": {
      "value": "itup-scorecard"
    },
    "location": {
      "value": "centralus"
    },
    "deploymentMode": {
      "value": "hybrid"
    },
    "logRetentionInDays": {
      "value": 90
    },
    "enableVmInsightsMap": {
      "value": false
    },
    "enableScheduledQueryAlerts": {
      "value": true
    },
    "heartbeatMissingMinutes": {
      "value": 15
    },
    "alertEmailReceivers": {
      "value": []
    },
    "grantGrafanaMonitoringReader": {
      "value": true
    },
    "tags": {
      "value": {
        "environment": "dev"
      }
    }
  }
}